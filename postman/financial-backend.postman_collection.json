              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/accounts/{{accId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","accounts","{{accId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Primary Checking\",\n  \"description\": \"Day-to-day expenses\"\n}" }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/accounts/{{accId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","accounts","{{accId}}"] }
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Summary (all time)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has required fields', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d).to.have.property('totalIncome');",
                  "  pm.expect(d).to.have.property('totalExpense');",
                  "  pm.expect(d).to.have.property('netBalance');",
                  "  pm.expect(d).to.have.property('transactionCounts');",
                  "});",
                  "pm.test('Amounts are strings (not floats)', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(typeof d.totalIncome).to.equal('string');",
                  "  pm.expect(typeof d.totalExpense).to.equal('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/dashboard/summary", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","dashboard","summary"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"totalIncome\": \"8500.00\",\n    \"totalExpense\": \"3200.50\",\n    \"netBalance\": \"5299.50\",\n    \"transactionCounts\": { \"income\": 5, \"expense\": 12, \"total\": 17 },\n    \"period\": { \"startDate\": null, \"endDate\": null },\n    \"cached\": false\n  }\n}"
            }
          ]
        },
        {
          "name": "Summary (date range)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/finance/dashboard/summary?startDate=2026-01-01T00:00:00Z&endDate=2026-03-31T23:59:59Z",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","finance","dashboard","summary"],
              "query": [
                { "key": "startDate", "value": "2026-01-01T00:00:00Z" },
                { "key": "endDate",   "value": "2026-03-31T23:59:59Z" }
              ]
            }
          }
        },
        {
