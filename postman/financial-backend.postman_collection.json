          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/dashboard/category-breakdown?type=EXPENSE", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","dashboard","category-breakdown"], "query": [{ "key": "type", "value": "EXPENSE" }] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
