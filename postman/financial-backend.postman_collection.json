            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/dashboard/monthly-trends?months=12", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","dashboard","monthly-trends"], "query": [{ "key": "months", "value": "12" }] }
          },
          "response": [
            {
