{
  "info": {
    "name": "Secure Financial Backend API",
    "description": "Complete collection for the FAANG-level Financial Data Processing & Access Control Backend. \n\n**Setup:**\n1. Set `baseUrl` variable to your server (default: http://localhost:3000)\n2. Run 'Login' to auto-populate `accessToken`\n3. All finance endpoints use `accessToken` automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "",                      "type": "string" },
    { "key": "txId",        "value": "",                      "type": "string" },
    { "key": "catId",       "value": "",                      "type": "string" },
    { "key": "accId",       "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass1!@#\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"code\": \"SUCCESS\",\n  \"message\": \"User registered successfully\",\n  \"data\": { \"user\": { \"id\": \"uuid\", \"name\": \"Test User\", \"email\": \"testuser@example.com\", \"role\": \"USER\" } }\n}"
            }
          ]
        },
        {
          "name": "Login (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  console.log('✅ Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"{{SEED_USER_PASSWORD}}\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"accessToken\": \"eyJ...\",\n    \"user\": { \"id\": \"uuid\", \"role\": \"USER\" }\n  }\n}"
            },
            {
              "name": "401 Invalid credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"code\": \"INVALID_CREDENTIALS\",\n  \"message\": \"Invalid email or password\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "💰 Transactions",
      "item": [
        {
          "name": "Create Transaction (INCOME)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('txId', json.data.transaction.id);",
                  "  console.log('✅ txId saved:', json.data.transaction.id);",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Amount is string', () => {",
                  "  const tx = pm.response.json().data.transaction;",
                  "  pm.expect(typeof tx.amount).to.equal('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"INCOME\",\n  \"amount\": \"5000.00\",\n  \"description\": \"Monthly salary\",\n  \"date\": \"{{$isoTimestamp}}\",\n  \"currency\": \"USD\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Transaction created\",\n  \"data\": {\n    \"transaction\": {\n      \"id\": \"uuid\",\n      \"type\": \"INCOME\",\n      \"amount\": \"5000.00\",\n      \"currency\": \"USD\",\n      \"description\": \"Monthly salary\",\n      \"date\": \"2026-04-02T10:00:00.000Z\",\n      \"category\": null,\n      \"account\": null\n    }\n  }\n}"
            },
            {
              "name": "422 Float amount rejected",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"code\": \"VALIDATION_ERROR\",\n  \"message\": \"Validation failed\",\n  \"errors\": [{ \"field\": \"amount\", \"message\": \"amount must be a positive number with up to 2 decimal places\" }]\n}"
            }
          ]
        },
        {
          "name": "Create Transaction (EXPENSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"EXPENSE\",\n  \"amount\": \"49.99\",\n  \"description\": \"Grocery shopping\",\n  \"date\": \"{{$isoTimestamp}}\",\n  \"currency\": \"USD\"\n}"
            }
          }
        },
        {
          "name": "List Transactions (paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('pagination');",
                  "  pm.expect(data.pagination).to.have.property('total');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/finance/transactions?page=1&limit=10&sortBy=date&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","finance","transactions"],
              "query": [
                { "key": "page",      "value": "1" },
                { "key": "limit",     "value": "10" },
                { "key": "sortBy",    "value": "date" },
                { "key": "sortOrder", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "List Transactions (filter by type)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/finance/transactions?type=EXPENSE&startDate=2026-01-01T00:00:00Z&endDate=2026-12-31T23:59:59Z",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","finance","transactions"],
              "query": [
                { "key": "type",      "value": "EXPENSE" },
                { "key": "startDate", "value": "2026-01-01T00:00:00Z" },
                { "key": "endDate",   "value": "2026-12-31T23:59:59Z" }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions/{{txId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions","{{txId}}"] }
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"code\": \"TRANSACTION_NOT_FOUND\",\n  \"message\": \"Transaction not found\"\n}"
            }
          ]
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions/{{txId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions","{{txId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Monthly salary (updated)\",\n  \"amount\": \"5500.00\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction (soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions/{{txId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions","{{txId}}"] }
          }
        },
        {
          "name": "Restore Transaction (ADMIN only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions/{{txId}}/restore", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions","{{txId}}","restore"] }
          },
          "response": [
            {
              "name": "403 Forbidden (non-admin)",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"code\": \"FORBIDDEN\",\n  \"message\": \"Access denied: insufficient role\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "🗂️ Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/categories", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","categories"] }
          }
        },
        {
          "name": "List Categories (INCOME only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/finance/categories?type=INCOME",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","finance","categories"],
              "query": [{ "key": "type", "value": "INCOME" }]
            }
          }
        },
        {
          "name": "Create Custom Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('catId', pm.response.json().data.category.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/categories", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Side Project\",\n  \"type\": \"INCOME\",\n  \"color\": \"#8BC34A\",\n  \"icon\": \"🚀\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/categories/{{catId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","categories","{{catId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Side Project (updated)\",\n  \"color\": \"#4CAF50\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/categories/{{catId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","categories","{{catId}}"] }
          },
          "response": [
            {
              "name": "409 Category in use",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"code\": \"CATEGORY_IN_USE\",\n  \"message\": \"Cannot delete category with 3 active transaction(s). Re-assign transactions first.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "🏦 Accounts",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","accounts"] }
          }
        },
        {
          "name": "Create Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('accId', pm.response.json().data.account.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","accounts"] },
            "body": {
