    {
      "name": "🔒 Security Tests",
      "item": [
        {
          "name": "IDOR — Access other user's transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('IDOR blocked → 404 (not 200 or 403)', () => {",
                  "  pm.expect(pm.response.code).to.equal(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions","00000000-0000-0000-0000-000000000000"] }
          }
        },
        {
          "name": "Mass Assignment — userId in body ignored",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response transaction belongs to authenticated user', () => {",
                  "  if (pm.response.code === 201) {",
                  "    const tx = pm.response.json().data.transaction;",
                  "    pm.expect(tx.userId).to.not.equal('admin-uuid-here');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"INCOME\",\n  \"amount\": \"9999.99\",\n  \"description\": \"Mass assignment test\",\n  \"date\": \"{{$isoTimestamp}}\",\n  \"userId\": \"admin-uuid-here\"\n}"
            }
          }
        },
        {
          "name": "Injection — Script in description",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('XSS escaped in response', () => {",
                  "  const body = pm.response.text();",
                  "  pm.expect(body).to.not.include('<script>');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/finance/transactions", "host": ["{{baseUrl}}"], "path": ["api","v1","finance","transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"EXPENSE\",\n  \"amount\": \"1.00\",\n  \"description\": \"<script>alert('xss')</script>\",\n  \"date\": \"{{$isoTimestamp}}\"\n}"
            }
          }
        }
      ]
    }
  ]
