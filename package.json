{
  "name": "secure-financial-backend",
  "version": "2.0.0",
  "description": "FAANG-level Financial Data Processing & Access Control Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npx prisma generate",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "seed": "node prisma/seed.js",
    "db:setup": "npm run migrate && npm run seed",
    "test":          "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
"test:watch":    "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
"test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit",
    "generate-keys": "node scripts/generate-keys.js",
    "lint": "eslint src/ --ext .js",
    "studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "argon2": "^0.44.0",
    "axios": "^1.6.8",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "otpauth": "^9.3.4",
    "prom-client": "^15.1.2",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.2.0",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.11.0",
    "supertest": "^7.2.2"
  },
"jest": {
  "testEnvironment": "node",
  "transform": {},
  "testMatch": ["**/tests/**/*.test.js"],
  "collectCoverageFrom": ["src/**/*.js", "!src/metrics/**", "!src/shared/config/swagger.js"],
  "coverageThreshold": {
    "global": { "branches": 60, "functions": 70, "lines": 70, "statements": 70 }
  } 
},
  "engines": {
    "node": ">=20.0.0"
  }
}
