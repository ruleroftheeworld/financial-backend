{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "title": "Financial Backend — Observability",
  "uid":   "financial-backend-v2",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "HTTP Requests / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(iam_requests_total[1m]) * 60", "legendFormat": "req/min" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "4xx Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(iam_requests_total{status=~\"4..\"}[5m])) / sum(rate(iam_requests_total[5m])) * 100", "legendFormat": "4xx %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 10, "color": "red" }] } }
    },
    {
      "id": 3, "type": "stat", "title": "Active Rate Limit Hits",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(iam_rate_limit_hits_total[5m])", "legendFormat": "hits" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat", "title": "Auth Failures (5m)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "increase(iam_auth_failures_total[5m])", "legendFormat": "failures" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "red" }] } }
    },
    {
      "id": 10, "type": "timeseries", "title": "HTTP Request Rate by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (status) (rate(iam_requests_total[1m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Finance Transactions Created",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (type) (increase(finance_transactions_total{action=\"create\"}[5m]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 20, "type": "timeseries", "title": "Finance API Latency (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum(rate(finance_api_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum(rate(finance_api_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum(rate(finance_api_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 21, "type": "timeseries", "title": "Login Duration (p95)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum(rate(iam_login_duration_seconds_bucket[5m])) by (le))", "legendFormat": "login p95" }
      ]
    },
    {
      "id": 30, "type": "stat", "title": "Total Transactions Created",
      "gridPos": { "x": 0, "y": 20, "w": 4, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(finance_transactions_total{action=\"create\"})", "legendFormat": "total" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 31, "type": "stat", "title": "INCOME Transactions",
      "gridPos": { "x": 4, "y": 20, "w": 4, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(finance_transactions_total{action=\"create\",type=\"INCOME\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "value": 0, "color": "green" }] } }
    },
    {
      "id": 32, "type": "stat", "title": "EXPENSE Transactions",
      "gridPos": { "x": 8, "y": 20, "w": 4, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(finance_transactions_total{action=\"create\",type=\"EXPENSE\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "thresholds": { "steps": [{ "value": 0, "color": "orange" }] } }
    },
    {
      "id": 33, "type": "stat", "title": "Dashboard Cache Hit Rate",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(finance_dashboard_cache_hits_total{result=\"hit\"}) / sum(finance_dashboard_cache_hits_total) * 100", "legendFormat": "hit %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "unit": "percent" }
    },
    {
      "id": 40, "type": "timeseries", "title": "IP Bans Issued",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "increase(iam_ip_bans_total[5m])", "legendFormat": "bans/5m" }
      ]
    },
    {
      "id": 41, "type": "timeseries", "title": "RBAC / ABAC Denials",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "increase(iam_authorization_failures_total[5m])", "legendFormat": "{{type}}" }
      ]
    }
  ]
}
